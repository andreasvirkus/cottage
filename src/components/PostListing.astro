---
import FormattedDate from './FormattedDate.astro'
import { getAsciiSnowflake } from '../utils/snowflakes'

interface Props {
  slug: string
  gradient: string
  title: string
  date: Date
}

const { date, slug, title, gradient } = Astro.props
const ascii = getAsciiSnowflake(slug)
---
<a href={`/thoughts/${slug}/`} data-sound="mouseClick" class="gradient" style={`--hero-gradient: ${gradient}`} transition:name={`post-hero-${slug}`}>
  <pre class="ascii" aria-hidden="true">{ascii}</pre>
  <div class="card">
    <h4 class="title" transition:name={`post-title-${slug}`}>{title}</h4>
    <div class="date">
      <FormattedDate date={date} />
    </div>
  </div>
</a>

<style>
@property --angle {
  syntax: '<angle>';
  inherits: false;
  initial-value: 10deg;
}
a {
  display: block;
  border: none;
  box-shadow: none;
}
a:hover {
  border: none;
}
a:hover .date {
  opacity: 1;
}

.gradient {
  position: relative;
  display: flex;
  flex-direction: column;

  background-image: var(--hero-gradient);
  min-height: 84px;
  padding: 0.625rem;
  opacity: 0.9;
  border-radius: 0.25rem;
  mix-blend-mode: luminosity;
  overflow: hidden;
  transition:
    opacity 0.3s cubic-bezier(0.85, 0, 0.15, 1),
    --angle 0.6s cubic-bezier(0.85, 0, 0.15, 1);
}
.ascii {
  position: absolute;
  inset: 0;
  margin: 0;
  padding: 0;
  pointer-events: none;
  user-select: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono, ui-monospace, monospace);
  font-size: 0.6rem;
  line-height: 1.05;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 0 3px rgba(0, 0, 0, 0.25);
  white-space: pre;
  overflow: hidden;
}
.gradient:hover {
  opacity: 1;
  --angle: 190deg;
  mix-blend-mode: normal;
  opacity: 1;
}
.card {
  position: relative;
  flex: 1;
  background-color: #22222270;
  padding: 0.625rem;
  height: 100%;
  border-radius: 4px;
}
.title,
.date {
  color: white;
  padding: 0.25rem;
  border-radius: 4px;
}
.title {
  margin: 0 0 0.25rem;
  line-height: 1;
  background-color: #222;
}
.date {
  margin: 0;
  font-size: 0.8em;
}
a:hover h4,
a:hover .date {
  /* color: var(--accent); */
}

.tag-label {
  border-radius: 4px;
  background-color: var(--code-background-color);
  padding: 0.5em;
  font-family: var(--font-mono);
  font-size: 0.8em;
  cursor: var(--cursor-pointer), pointer;
}

/* TODO: Hide once there's a nice way to style checked state */
label input {
  position: fixed;
  opacity: 0;
  visibility: hidden;
}

.tag input:checked ~ .tag-label {
  background-color: var(--link-color);
}

@media (max-width: 720px) {
  a {
    width: 96%;
    text-align: center;
    margin-bottom: 1em;
  }

  .gradient {
    opacity: 1;
    height: 60px;
    mix-blend-mode: normal;
  }
}
</style>
