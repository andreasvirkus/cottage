---
import type { CollectionEntry } from 'astro:content'
import Base from '../layouts/Base.astro'
import FormattedDate from '../components/FormattedDate.astro'
import { getConicGradient } from '../utils/conic-art'
import { getAsciiSnowflake } from '../utils/snowflakes'
import TagsList from '../components/TagsList.astro'

type Props = CollectionEntry<'thoughts'>

const { title, pubDate, updatedDate, readingTime, tags } = Astro.props.data
const { slug } = Astro.params
const ascii = getAsciiSnowflake(slug || '')
---

<Base>
  <article>
    <div class="hero-image" style={`--hero-gradient: ${getConicGradient(slug || '')}`} transition:name={`post-hero-${slug}`}>
      <pre class="ascii" aria-hidden="true">{ascii}</pre>
    </div>

    <div class="title">
      <h1 transition:name={`post-title-${slug}`}>{title}</h1>
      <div class="date">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <div class="last-updated-on">
              Last updated on <FormattedDate date={updatedDate} />
            </div>
          )
        }
      </div>
      {
        readingTime && (
          <div class="reading-time">
            {readingTime} {readingTime === 1 ? 'minute' : 'minutes'} to read
          </div>
        )
      }
    </div>

    <TagsList centered tags={tags ?? []} />

    <hr />

    <slot />
  </article>
</Base>

<style>
  main {
    width: calc(100% - 2em);
    max-width: 100%;
    margin: 0;
  }
  .hero-image {
    position: relative;
    width: 100%;
    background-image: var(--hero-gradient);
    animation: 3s conic infinite;
    overflow: hidden;
  }
  .hero-image {
    display: block;
    margin: 0 auto;
    height: 200px;
    box-shadow: var(--box-shadow);
  }
  .ascii {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 0;
    pointer-events: none;
    user-select: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.8rem;
    line-height: 1;
    letter-spacing: 0.35em;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 0 6px rgba(0, 0, 0, 0.25);
    white-space: pre;
    overflow: hidden;
  }
  .title {
    padding-top: 1em 0;
    text-align: center;
  }
  .title h1 {
    margin-bottom: 0.5em;
  }
  .date {
    margin-bottom: 0.5em;
    font-size: 0.8em;
  }
  .last-updated-on {
    font-style: italic;
  }
</style>
